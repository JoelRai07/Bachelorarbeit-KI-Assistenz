
@article{he_enhancing_2025,
	title = {Enhancing Web Accessibility: Automated Detection of Issues with Generative {AI}},
	volume = {2},
	url = {https://dl.acm.org/doi/10.1145/3729371},
	doi = {10.1145/3729371},
	shorttitle = {Enhancing Web Accessibility},
	abstract = {Websites are integral to people’s daily lives, with billions in use today. However, due to limited awareness of accessibility and its guidelines, developers often release web apps that are inaccessible to people with disabilities, who make up around 16\% of the global population. To ensure a baseline of accessibility, software engineers rely on automated checkers that assess a webpage’s compliance based on predefined rules. Unfortunately, these tools typically cover only a small subset of accessibility guidelines and often overlook violations that require a semantic understanding of the webpage. The advent of generative {AI}, known for its ability to comprehend textual and visual content, has created new possibilities for detecting accessibility violations. We began by studying the most widely used guideline, {WCAG}, to determine the testable success criteria that generative {AI} could address. This led to the development of an automated tool called {GenA}11y, which extracts elements from a page related to each success criterion and inputs them into an {LLM} prompted to detect accessibility issues on the web. Evaluations of {GenA}11y showed its effectiveness, with a precision of 94.5\% and a recall of 87.61\%. Additionally, when tested on real websites, {GenA}11y identified an average of eight more types of accessibility violations than the combination of existing tools.},
	pages = {FSE101:2264--FSE101:2287},
	issue = {{FSE}},
	journaltitle = {Proc. {ACM} Softw. Eng.},
	author = {He, Ziyao and Huq, Syed Fatiul and Malek, Sam},
	urldate = {2026-02-24},
	date = {2025-06-19},
	keywords = {Hoch, Wichtig},
	file = {Full Text PDF:C\:\\Users\\joely\\Zotero\\storage\\RH5HIN7F\\He et al. - 2025 - Enhancing Web Accessibility Automated Detection of Issues with Generative AI.pdf:application/pdf},
}
