	file = {Full Text PDF:C\:\\Users\\joely\\Zotero\\storage\\4NUCZR9L\\Abou-Zahra et al. - 2018 - Artificial Intelligence (AI) for Web Accessibility Is Conformance Evaluation a Way Forward.pdf:application/pdf},
