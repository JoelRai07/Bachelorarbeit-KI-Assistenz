	keywords = {Hoch},
	file = {Full Text PDF:C\:\\Users\\joely\\Zotero\\storage\\WI7MG7P4\\Pool - 2023 - Testaro Efficient Ensemble Testing for Web Accessibility.pdf:application/pdf},
}


