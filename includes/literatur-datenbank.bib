@misc{huang_access_2024,
	title = {{ACCESS}: Prompt Engineering for Automated Web Accessibility Violation Corrections},
	url = {http://arxiv.org/abs/2401.16450},
	doi = {10.48550/arXiv.2401.16450},
	shorttitle = {{ACCESS}},
	abstract = {With the increasing need for inclusive and user-friendly technology, web accessibility is crucial to ensuring equal access to online content for individuals with disabilities, including visual, auditory, cognitive, or motor impairments. Despite the existence of accessibility guidelines and standards such as Web Content Accessibility Guidelines ({WCAG}) and the Web Accessibility Initiative (W3C), over 90\% of websites still fail to meet the necessary accessibility requirements. For web users with disabilities, there exists a need for a tool to automatically fix web page accessibility errors. While research has demonstrated methods to find and target accessibility errors, no research has focused on effectively correcting such violations. This paper presents a novel approach to correcting accessibility violations on the web by modifying the document object model ({DOM}) in real time with foundation models. Leveraging accessibility error information, large language models ({LLMs}), and prompt engineering techniques, we achieved greater than a 51\% reduction in accessibility violation errors after corrections on our novel benchmark: {ACCESS}. Our work demonstrates a valuable approach toward the direction of inclusive web content, and provides directions for future research to explore advanced methods to automate web accessibility.},
	number = {{arXiv}:2401.16450},
	publisher = {{arXiv}},
	author = {Huang, Calista and Ma, Alyssa and Vyasamudri, Suchir and Puype, Eugenie and Kamal, Sayem and Garcia, Juan Belza and Cheema, Salar and Lutz, Michael},
	urldate = {2026-02-25},
	date = {2024-02-10},
	eprinttype = {arxiv},
	eprint = {2401.16450 [cs]},
	keywords = {Computer Science - Human-Computer Interaction, Computer Science - Software Engineering, Computer Science - Artificial Intelligence, Hoch, Wichtig},
	file = {Full Text PDF:C\:\\Users\\joely\\Zotero\\storage\\ACKUU7VH\\Huang et al. - 2024 - ACCESS Prompt Engineering for Automated Web Accessibility Violation Corrections.pdf:application/pdf;Snapshot:C\:\\Users\\joely\\Zotero\\storage\\IKR8U7DD\\2401.html:text/html},
}


@inproceedings{kodithuwakku_assessing_2025,
	title = {Assessing the Limits of Automated Accessibility Testing: Insights for {QA} Engineers and Tool Developers},
	url = {https://ieeexplore.ieee.org/document/10963173},
	doi = {10.1109/ICARC64760.2025.10963173},
	shorttitle = {Assessing the Limits of Automated Accessibility Testing},
	abstract = {This research aims to evaluate the effectiveness of automated accessibility testing tools by assessing their coverage and identifying areas where manual testing remains essential. The research process begins with the selection of widely used accessibility testing tools, informed by both existing literature and a survey conducted with Sri Lankan {QA} engineers. Seven popular tools Axe, Lighthouse, {WAVE}, A11y, Includia Accessibility Checker, Accessibility Insights and Siteimprove were chosen for evaluation. Ten websites were selected for testing, and both manual testing and automated testing were conducted using {WCAG} guidelines (Levels A and {AA}). The accessibility criteria were further categorized according to different disability types. The evaluation focused on key metrics such as True Positives ({TP}), False Positives ({FP}), Issue Coverage Ratio ({ICR}), and Coverage Error Ratio ({CER}) for each tool. The findings provide insights into which accessibility issues can be effectively addressed by automated tools and which require manual intervention. These results will guide {QA} engineers in making informed decisions about tool selection and manual testing practices. The research offers valuable feedback for tool developers to identify areas for improvement, suggest new features, and guide the development of future tools.},
	eventtitle = {2025 5th International Conference on Advanced Research in Computing ({ICARC})},
	pages = {1--6},
	booktitle = {2025 5th International Conference on Advanced Research in Computing ({ICARC})},
	author = {Kodithuwakku, Tashmi and Wickramaarachchi, Dilani},
	urldate = {2026-02-24},
	date = {2025-02},
	keywords = {Testing, Accessibility Testing, Automated Accessibility Testing Tools, Guidelines, Manuals, Measurement, Surveys, Web Content Accessibility Guidelines ({WCAG}), Hoch},
	file = {Full Text PDF:C\:\\Users\\joely\\Zotero\\storage\\UAMNXE6I\\Kodithuwakku und Wickramaarachchi - 2025 - Assessing the Limits of Automated Accessibility Testing Insights for QA Engineers and Tool Develope.pdf:application/pdf},
}


@inproceedings{pool_testaro_2023,
	location = {New York, {NY}, {USA}},
	title = {Testaro: Efficient Ensemble Testing for Web Accessibility},
	isbn = {979-8-4007-0220-4},
	url = {https://dl.acm.org/doi/10.1145/3597638.3614505},
	doi = {10.1145/3597638.3614505},
	series = {{ASSETS} '23},
	shorttitle = {Testaro},
	abstract = {As automated web accessibility testing tools become enriched with new and improved tests, it can be impractical to leverage those advances. Each tool offers unique benefits, but effectively using multiple tools would require integrating them into a uniform testing and reporting scheme. Such integration is complex, because tools vary in what they try to detect, what they actually detect, and how they classify, describe, and report defects. Consequently, testers typically use only one tool. Testaro[7] is a novel open-source {NPM} package that checks compliance with about 650 rules defined by an ensemble of 8 tools: alfa, Axe, Equal Access, {HTML} {CodeSniffer}, Nu Html Checker, {QualWeb}, Testaro, and {WAVE}. Attendees at the demonstration will, within 5 minutes, create jobs for Testaro, run them, and generate unified reports documenting more accessibility issues than any single tool can discover.},
	pages = {1--4},
	booktitle = {Proceedings of the 25th International {ACM} {SIGACCESS} Conference on Computers and Accessibility},
